<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane minHeight="600.0" minWidth="800.0" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="ca.cegep.pokedex.controleur.PokedexControleur">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <left>
        <VBox spacing="10.0" prefWidth="250.0" BorderPane.alignment="CENTER">
            <children>
                <HBox spacing="5.0">
                    <children>
                        <TextField fx:id="champRecherche" promptText="Nom ou ID..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="boutonRecherche" mnemonicParsing="false" onAction="#actionRechercher" text="🔍" />
                    </children>
                </HBox>
                <Label text="Pokémon Capturés :" style="-fx-font-weight: bold;" />
                <ListView fx:id="listeCaptures" VBox.vgrow="ALWAYS" />
                <Button fx:id="boutonSupprimer" mnemonicParsing="false" onAction="#actionSupprimer" text="Supprimer" maxWidth="Infinity" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </left>
    <center>
        <VBox fx:id="conteneurFiche" alignment="TOP_CENTER" spacing="20.0" BorderPane.alignment="CENTER">
        <children>
                <Label fx:id="labelNomPokemon" text="Pokédex Ultime" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                <Label fx:id="labelTypes" text="Types: --" style="-fx-font-style: italic;" />
                <ImageView fx:id="imagePokemon" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />

                <GridPane hgap="10.0" vgap="10.0" maxWidth="400.0">
                    <children>
                        <Label text="PV" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ProgressBar fx:id="barrePv" progress="0.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Attaque" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ProgressBar fx:id="barreAttaque" progress="0.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Défense" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <ProgressBar fx:id="barreDefense" progress="0.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Att. Spé." GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <ProgressBar fx:id="barreAttaqueSp" progress="0.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Déf. Spé." GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <ProgressBar fx:id="barreDefenseSp" progress="0.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <Label text="Vitesse" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <ProgressBar fx:id="barreVitesse" progress="0.0" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>
